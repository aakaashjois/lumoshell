#!/usr/bin/env bash

set -euo pipefail

resolve_realpath() {
  local path="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$path"
    return
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "$path"
    return
  fi

  (
    cd -- "$(dirname -- "$path")"
    printf '%s/%s\n' "$(pwd -P)" "$(basename -- "$path")"
  )
}

SCRIPT_PATH="$(resolve_realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
VERSION_PLACEHOLDER="__LUMOSHELL_VERSION__"

resolve_version() {
  # Release workflow injects the tag version into VERSION_PLACEHOLDER.
  if [[ "$VERSION_PLACEHOLDER" != "__LUMOSHELL_VERSION__" ]]; then
    echo "$VERSION_PLACEHOLDER"
    return
  fi

  # Homebrew installs from Cellar paths like:
  # /opt/homebrew/Cellar/lumoshell/<version>/bin/lumoshell
  if [[ "$SCRIPT_PATH" =~ /Cellar/lumoshell/([^/]+)/bin/lumoshell$ ]]; then
    echo "${BASH_REMATCH[1]}"
    return
  fi

  # In development checkouts, prefer the latest git tag if available.
  if command -v git >/dev/null 2>&1; then
    local repo_root
    repo_root="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      local remote_url
      remote_url="$(git -C "$repo_root" remote get-url origin 2>/dev/null || true)"
      if [[ "$remote_url" == *"aakaashjois/lumoshell"* ]]; then
        local tag
        tag="$(git -C "$repo_root" describe --tags --abbrev=0 2>/dev/null || true)"
        if [[ -n "$tag" ]]; then
          echo "${tag#v}"
          return
        fi
      fi
    fi
  fi

  echo "dev"
}

VERSION="$(resolve_version)"

usage() {
  cat <<'EOF'
Usage:
  lumoshell <command> [options]

Commands:
  apply [--dry-run] [--verbose]
  profile set <light|dark> <profile-name>
  profile show
  profile reset <light|dark|all>
  logs
  install
  uninstall
  doctor
  version
  help
EOF
}

profile_usage() {
  cat <<'EOF'
Usage:
  lumoshell profile set <light|dark> <profile-name>
  lumoshell profile show
  lumoshell profile reset <light|dark|all>
EOF
}

profile_store_domain="com.user.lumoshell"
agent_log_path="${HOME}/Library/Logs/lumoshell/appearance-sync-agent.log"
profile_key_for_mode() {
  case "$1" in
    light) echo "LightProfile" ;;
    dark) echo "DarkProfile" ;;
    *)
      echo "Invalid mode: $1 (expected: light or dark)" >&2
      exit 1
      ;;
  esac
}

profile_set() {
  local mode="${1:-}"
  local profile_name="${2:-}"
  if [[ -z "$mode" || -z "$profile_name" || -n "${3:-}" ]]; then
    profile_usage
    exit 1
  fi

  local key
  key="$(profile_key_for_mode "$mode")"
  defaults write "$profile_store_domain" "$key" -string "$profile_name"
  echo "Set $mode profile to \"$profile_name\"."
  echo "Applying updated profile configuration..."
  exec "$SCRIPT_DIR/lumoshell-apply"
}

profile_show() {
  if [[ -n "${1:-}" ]]; then
    profile_usage
    exit 1
  fi

  local light_value dark_value
  light_value="$(defaults read "$profile_store_domain" LightProfile 2>/dev/null || true)"
  dark_value="$(defaults read "$profile_store_domain" DarkProfile 2>/dev/null || true)"

  if [[ -n "$light_value" ]]; then
    echo "light: $light_value"
  else
    echo "light: (not set, defaults to Basic unless LUMOSHELL_PROFILE_LIGHT is set)"
  fi

  if [[ -n "$dark_value" ]]; then
    echo "dark: $dark_value"
  else
    echo "dark: (not set, defaults to Pro unless LUMOSHELL_PROFILE_DARK is set)"
  fi
}

profile_reset() {
  local target="${1:-}"
  if [[ -z "$target" || -n "${2:-}" ]]; then
    profile_usage
    exit 1
  fi

  case "$target" in
    light|dark)
      local key
      key="$(profile_key_for_mode "$target")"
      defaults delete "$profile_store_domain" "$key" >/dev/null 2>&1 || true
      echo "Reset $target profile override."
      ;;
    all)
      defaults delete "$profile_store_domain" >/dev/null 2>&1 || true
      echo "Reset all profile overrides."
      ;;
    *)
      echo "Invalid reset target: $target (expected: light, dark, or all)" >&2
      exit 1
      ;;
  esac

  echo "Applying updated profile configuration..."
  exec "$SCRIPT_DIR/lumoshell-apply"
}

validate_apply_args() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      --dry-run|--verbose|-h|--help) ;;
      *)
        echo "lumoshell apply supports only --dry-run and --verbose." >&2
        exit 1
        ;;
    esac
  done
}

show_logs() {
  if [[ -n "${1:-}" ]]; then
    echo "lumoshell logs does not accept positional arguments." >&2
    exit 1
  fi

  if [[ ! -f "$agent_log_path" ]]; then
    echo "No logs found at $agent_log_path"
    exit 0
  fi

  local cutoff_iso
  cutoff_iso="$(date -u -v-1H '+%Y-%m-%dT%H:%M:%SZ')"
  awk -v cutoff="$cutoff_iso" '
    NF == 0 { next }
    {
      ts=$1
      if (ts >= cutoff) {
        print $0
      }
    }
  ' "$agent_log_path"
}

cmd="${1:-help}"
if [[ "$cmd" == "help" || "$cmd" == "-h" || "$cmd" == "--help" ]]; then
  usage
  exit 0
fi
shift

case "$cmd" in
  apply)
    validate_apply_args "$@"
    exec "$SCRIPT_DIR/lumoshell-apply" "$@"
    ;;
  profile)
    subcmd="${1:-}"
    if [[ -z "$subcmd" || "$subcmd" == "help" || "$subcmd" == "-h" || "$subcmd" == "--help" ]]; then
      profile_usage
      exit 0
    fi
    shift
    case "$subcmd" in
      set)
        profile_set "${1:-}" "${2:-}"
        ;;
      show)
        profile_show "$@"
        ;;
      reset)
        profile_reset "${1:-}"
        ;;
      *)
        echo "Unknown profile command: $subcmd" >&2
        profile_usage
        exit 1
        ;;
    esac
    ;;
  install)
    exec "$SCRIPT_DIR/lumoshell-install" "$@"
    ;;
  uninstall)
    exec "$SCRIPT_DIR/lumoshell-uninstall" "$@"
    ;;
  logs)
    show_logs "${1:-}"
    ;;
  doctor)
    echo "lumoshell version: $VERSION"
    echo "lumoshell-apply: $(command -v lumoshell-apply || true)"
    echo "lumoshell-appearance-sync-agent: $(command -v lumoshell-appearance-sync-agent || true)"
    echo "Terminal profile mode detection:"
    "$SCRIPT_DIR/lumoshell-apply" --dry-run || true
    ;;
  version)
    echo "$VERSION"
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac

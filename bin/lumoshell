#!/usr/bin/env bash

set -euo pipefail

resolve_realpath() {
  local path="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$path"
    return
  fi

  (
    cd -- "$(dirname -- "$path")"
    printf '%s/%s\n' "$(pwd -P)" "$(basename -- "$path")"
  )
}

SCRIPT_PATH="$(resolve_realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
VERSION_PLACEHOLDER="__LUMOSHELL_VERSION__"

resolve_version() {
  # Release workflow injects the tag version into VERSION_PLACEHOLDER.
  if [[ "$VERSION_PLACEHOLDER" != "__LUMOSHELL_VERSION__" ]]; then
    echo "$VERSION_PLACEHOLDER"
    return
  fi

  # Homebrew installs from Cellar paths like:
  # /opt/homebrew/Cellar/lumoshell/<version>/bin/lumoshell
  if [[ "$SCRIPT_PATH" =~ /Cellar/lumoshell/([^/]+)/bin/lumoshell$ ]]; then
    echo "${BASH_REMATCH[1]}"
    return
  fi

  # In development checkouts, prefer the latest git tag if available.
  if command -v git >/dev/null 2>&1; then
    local repo_root
    repo_root="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$repo_root" ]]; then
      local remote_url
      remote_url="$(git -C "$repo_root" remote get-url origin 2>/dev/null || true)"
      if [[ "$remote_url" == *"aakaashjois/lumoshell"* ]]; then
        local tag
        tag="$(git -C "$repo_root" describe --tags --abbrev=0 2>/dev/null || true)"
        if [[ -n "$tag" ]]; then
          echo "${tag#v}"
          return
        fi
      fi
    fi
  fi

  echo "dev"
}

VERSION="$(resolve_version)"

usage() {
  cat <<'EOF'
Usage:
  lumoshell <command> [options]

Commands:
  apply [--dry-run] [--verbose]
  setup [--reset]
  status
  logs
  install
  uninstall
  doctor
  version
  help
EOF
}

profile_store_domain="com.user.lumoshell"
agent_log_path="${HOME}/Library/Logs/lumoshell/appearance-sync-agent.log"

profile_key_for_mode() {
  case "$1" in
    light) echo "LightProfile" ;;
    dark) echo "DarkProfile" ;;
    *)
      echo "Invalid mode: $1 (expected: light or dark)" >&2
      exit 1
      ;;
  esac
}

status() {
  if [[ -n "${1:-}" ]]; then
    echo "lumoshell status does not accept any arguments." >&2
    exit 1
  fi

  local light_value dark_value
  light_value="$(defaults read "$profile_store_domain" LightProfile 2>/dev/null || true)"
  dark_value="$(defaults read "$profile_store_domain" DarkProfile 2>/dev/null || true)"

  if [[ -n "$light_value" ]]; then
    echo "light: $light_value"
  else
    echo "light: (not set, defaults to Basic unless LUMOSHELL_PROFILE_LIGHT is set)"
  fi

  if [[ -n "$dark_value" ]]; then
    echo "dark: $dark_value"
  else
    echo "dark: (not set, defaults to Pro unless LUMOSHELL_PROFILE_DARK is set)"
  fi
}

interactive_select() {
  local prompt="$1"
  local default_val="$2"
  shift 2
  local options=("$@")
  local selected=0
  local key
  local input=""
  local last_previewed=""
  local original_profile=""

  original_profile="$(osascript -e 'tell application "Terminal" to try' -e 'get name of current settings of selected tab of front window' -e 'end try' 2>/dev/null || true)"

  for i in "${!options[@]}"; do
    if [[ "${options[$i]}" == "$default_val" ]]; then
      selected=$i
      break
    fi
  done

  tput civis >&2 || true
  trap '
    tput cnorm >&2 2>/dev/null || true;
    if [[ -n "${PREVIEW_PID:-}" ]] && kill -0 "$PREVIEW_PID" 2>/dev/null; then
      kill "$PREVIEW_PID" 2>/dev/null || true;
    fi;
    if [[ -n "${original_profile:-}" ]]; then
      osascript -e "tell application \"Terminal\" to try" -e "set current settings of selected tab of front window to settings set \"$original_profile\"" -e "end try" >/dev/null 2>&1;
    fi;
    exit 1
  ' INT

  echo "$prompt" >&2
  echo "----------------------------------------" >&2
  for i in "${!options[@]}"; do
    echo "" >&2
  done

  while true; do
    tput cuu ${#options[@]} >&2 || true
    
    local display_idx=1
    for i in "${!options[@]}"; do
      if [[ $i -eq $selected ]]; then
        printf "\r\033[K> %d) %s\n" "$display_idx" "${options[$i]}" >&2
      else
        printf "\r\033[K  %d) %s\n" "$display_idx" "${options[$i]}" >&2
      fi
      ((display_idx++))
    done

    if [[ "${options[$selected]}" != "${last_previewed:-}" ]]; then
      last_previewed="${options[$selected]}"
      if [[ -n "${PREVIEW_PID:-}" ]] && kill -0 "$PREVIEW_PID" 2>/dev/null; then
        kill "$PREVIEW_PID" 2>/dev/null || true
      fi
      osascript -e "tell application \"Terminal\" to try" -e "set current settings of selected tab of front window to settings set \"$last_previewed\"" -e "end try" >/dev/null 2>&1 &
      PREVIEW_PID=$!
    fi

    read -rsn1 key </dev/tty
    if [[ $key == $'\e' ]]; then
      read -rsn1 -t 0.05 key </dev/tty || true
      if [[ $key == '[' ]]; then
        read -rsn1 -t 0.05 key </dev/tty || true
        if [[ $key == 'A' ]]; then # Up
          ((selected--))
          if [[ $selected -lt 0 ]]; then selected=$((${#options[@]}-1)); fi
          input=""
        elif [[ $key == 'B' ]]; then # Down
          ((selected++))
          if [[ $selected -ge ${#options[@]} ]]; then selected=0; fi
          input=""
        fi
      fi
    elif [[ $key == '' || $key == ' ' ]]; then # Enter or Space
      break
    elif [[ "$key" =~ ^[0-9]$ ]]; then
      input="$input$key"
      local idx=$((input - 1))
      if [[ $idx -ge 0 && $idx -lt ${#options[@]} ]]; then
        selected=$idx
      else
        input="$key" 
        idx=$((input - 1))
        if [[ $idx -ge 0 && $idx -lt ${#options[@]} ]]; then
          selected=$idx
        fi
      fi
    else
      input=""
    fi
  done

  trap - INT
  tput cnorm >&2 || true
  
  echo "${options[$selected]}"
}

setup() {
  if [[ "${1:-}" == "--reset" ]]; then
    defaults delete "$profile_store_domain" >/dev/null 2>&1 || true
    echo "Reset all profile overrides."
    echo "Applying updated profile configuration..."
    exec "$SCRIPT_DIR/lumoshell-apply"
  elif [[ -n "${1:-}" ]]; then
    echo "lumoshell setup takes only the --reset option." >&2
    exit 1
  fi

  echo "Fetching available Terminal profiles..."
  local profiles
  # shellcheck disable=SC2016
  local jxa_script='
ObjC.import("Foundation");
var path = $( "~/Library/Preferences/com.apple.Terminal.plist" ).stringByExpandingTildeInPath;
var dict = $.NSDictionary.dictionaryWithContentsOfFile(path);
if (dict) {
  var settings = dict.objectForKey("Window Settings");
  if (settings) {
    var keys = settings.allKeys;
    var out = [];
    for (var i = 0; i < keys.count; i++) {
        out.push(keys.objectAtIndex(i).js);
    }
    out.join("\n");
  }
}
'
  IFS=$'\n' read -r -d '' -a profiles < <(osascript -l JavaScript -e "$jxa_script" 2>/dev/null && printf '\0')

  if [[ ${#profiles[@]} -eq 0 ]]; then
    echo "Failed to retrieve terminal profiles or none found." >&2
    exit 1
  fi

  local current_light current_dark
  current_light="$(defaults read "$profile_store_domain" LightProfile 2>/dev/null || echo "Basic")"
  current_dark="$(defaults read "$profile_store_domain" DarkProfile 2>/dev/null || echo "Pro")"

  local light_profile dark_profile
  
  cat <<'EOF' >&2

Lumoshell Setup
---------------
This setup will configure which Terminal profiles to use when macOS switches
between Light and Dark appearance.

You will first select your preferred profile for Light mode, followed by your
preferred profile for Dark mode. As you navigate the options, your current
Terminal tab will live-preview the selected theme.

(Hint: You can create or customize themes by opening Terminal -> Settings -> Profiles)

EOF

  light_profile="$(interactive_select "Select the Terminal profile to use for Light mode:" "$current_light" "${profiles[@]}")"
  echo "" >&2
  dark_profile="$(interactive_select "Select the Terminal profile to use for Dark mode:" "$current_dark" "${profiles[@]}")"

  local light_key dark_key
  light_key="$(profile_key_for_mode "light")"
  dark_key="$(profile_key_for_mode "dark")"

  defaults write "$profile_store_domain" "$light_key" -string "$light_profile"
  defaults write "$profile_store_domain" "$dark_key" -string "$dark_profile"

  echo "Set light profile to \"$light_profile\" and dark profile to \"$dark_profile\"."
  echo "Applying updated profile configuration..."
  exec "$SCRIPT_DIR/lumoshell-apply"
}

validate_apply_args() {
  local arg
  for arg in "$@"; do
    case "$arg" in
      --dry-run|--verbose|-h|--help) ;;
      *)
        echo "lumoshell apply supports only --dry-run and --verbose." >&2
        exit 1
        ;;
    esac
  done
}

show_logs() {
  if [[ -n "${1:-}" ]]; then
    echo "lumoshell logs does not accept positional arguments." >&2
    exit 1
  fi

  if [[ ! -f "$agent_log_path" ]]; then
    echo "No logs found at $agent_log_path"
    exit 0
  fi

  local cutoff_iso
  cutoff_iso="$(date -u -v-1H '+%Y-%m-%dT%H:%M:%SZ')"
  awk -v cutoff="$cutoff_iso" '
    NF == 0 { next }
    {
      ts=$1
      if (ts >= cutoff) {
        print $0
      }
    }
  ' "$agent_log_path"
}

cmd="${1:-help}"
if [[ "$cmd" == "help" || "$cmd" == "-h" || "$cmd" == "--help" ]]; then
  usage
  exit 0
fi
shift

case "$cmd" in
  apply)
    validate_apply_args "$@"
    exec "$SCRIPT_DIR/lumoshell-apply" "$@"
    ;;
  status)
    status "$@"
    ;;
  setup)
    setup "$@"
    ;;
  install)
    exec "$SCRIPT_DIR/lumoshell-install" "$@"
    ;;
  uninstall)
    exec "$SCRIPT_DIR/lumoshell-uninstall" "$@"
    ;;
  logs)
    show_logs "${1:-}"
    ;;
  doctor)
    echo "lumoshell version: $VERSION"
    echo "lumoshell-apply: $(command -v lumoshell-apply || true)"
    echo "lumoshell-appearance-sync-agent: $(command -v lumoshell-appearance-sync-agent || true)"
    echo "Terminal profile mode detection:"
    "$SCRIPT_DIR/lumoshell-apply" --dry-run || true
    ;;
  version)
    echo "$VERSION"
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage
    exit 1
    ;;
esac
